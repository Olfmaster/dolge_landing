			<noscript><style>.lazyload[data-src]{display:none !important;}</style></noscript><style>.lazyload{background-image:none !important;}.lazyload:before{background-image:none !important;}</style><script>// ─── AUTO-CONVERT (at) EMAILS & PLAIN PHONE TEXT TO LINKS ────────
document.addEventListener('DOMContentLoaded', function () {

  // Convert (at) emails → mailto links
  document.querySelectorAll('*:not(script):not(style)').forEach(function (el) {
    el.childNodes.forEach(function (node) {
      if (node.nodeType !== 3) return; // text nodes only
      var text = node.textContent;

      // Match pattern: anything(at)anything.tld
      if (/([\w.\-+]+)\(at\)([\w.\-]+\.[a-z]{2,})/i.test(text)) {
        var span = document.createElement('span');
        span.innerHTML = text.replace(
          /([\w.\-+]+)\(at\)([\w.\-]+\.[a-z]{2,})/gi,
          '<a href="mailto:$1@$2">$1@$2</a>'
        );
        node.parentNode.replaceChild(span, node);
      }
    });
  });

  // Convert Tel.: +xx xxx patterns → tel links
  document.querySelectorAll('*:not(script):not(style)').forEach(function (el) {
    el.childNodes.forEach(function (node) {
      if (node.nodeType !== 3) return;
      var text = node.textContent;

      if (/Tel\.?:?\s*\+?[\d\s\-\/]{7,}/i.test(text)) {
        var span = document.createElement('span');
        span.innerHTML = text.replace(
          /(Tel\.?:?\s*)(\+?[\d\s\-\/]{7,})/gi,
          function(match, prefix, number) {
            var clean = number.replace(/[\s\-\/]/g, '');
            if (!clean.startsWith('+')) clean = '+49' + clean.replace(/^0/, '');
            return prefix + '<a href="tel:' + clean + '">' + number + '</a>';
          }
        );
        node.parentNode.replaceChild(span, node);
      }
    });
  });

});</script><script>(function () {
  window.dataLayer = window.dataLayer || [];

  // ─── 2. SESSION DURATION ──────────────────────────────
  var SESSION_MINUTES = 2; // ← adjust later
  setTimeout(function () {
    window.dataLayer.push({ event: 'session_duration_threshold', minutes: SESSION_MINUTES });
  }, SESSION_MINUTES * 60 * 1000);

  // ─── 3. NEWSLETTER SIGNUP (CleverReach cr_form) ───────
  document.addEventListener('submit', function (e) {
    if (e.target.classList.contains('cr_form')) {
      window.dataLayer.push({
        event: 'newsletter_signup',
        form_location: window.location.pathname
      });
    }
  });

  // ─── 4. MORE THAN 5 PAGES VISITED ─────────────────────
  var count = parseInt(sessionStorage.getItem('ga_page_count') || '0', 10) + 1;
  sessionStorage.setItem('ga_page_count', count);
  if (count === 5) {
    window.dataLayer.push({ event: 'pages_visited_threshold', page_count: count });
  }

  // ─── 5. TIME ON CONTACT/ANSPRECHPARTNER PAGE ──────────
  var CONTACT_MINUTES = 1; // ← adjust later
  var contactPages = ['/kontakt/', '/kontakt/ansprechpartner/'];
  if (contactPages.some(function(p) { return window.location.pathname.includes(p); })) {
    setTimeout(function () {
      window.dataLayer.push({
        event: 'contact_page_time_threshold',
        minutes: CONTACT_MINUTES,
        page: window.location.pathname
      });
    }, CONTACT_MINUTES * 60 * 1000);
  }

  // ─── 6. CLICK ON EMAIL / PHONE LINKS ──────────────────
  document.addEventListener('click', function (e) {
    var link = e.target.closest('a[href^="mailto:"], a[href^="tel:"]');
    if (link) {
      window.dataLayer.push({
        event: 'contact_link_click',
        contact_type: link.href.startsWith('mailto:') ? 'email' : 'phone',
        contact_value: link.href.replace(/^mailto:|^tel:/, ''),
        page: window.location.pathname
      });
    }
  });

})();</script><!-- Event snippet for Landing page Conversion conversion page -->
