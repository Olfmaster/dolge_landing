  const wrap = document.querySelector(".kontakt-fab");
  if (!wrap) return;

  const toggle = () => {
    wrap.classList.toggle("small", window.scrollY > window.innerHeight * 0.7);
  };

  window.addEventListener("scroll", toggle, { passive: true });
  toggle(); // Initialzustand setzen
});
